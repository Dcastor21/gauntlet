# Local development
DATABASE_URL=postgresql+asyncpg://gauntlet:gauntlet_local@localhost:5432/gauntlet
REDIS_URL=redis://localhost:6379/0

# Clerk (get from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Worker internal auth
INTERNAL_WORKER_SECRET=local-dev-secret

# LLM Providers (add as you integrate each one)
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
COHERE_API_KEY=xxxxx
MISTRAL_API_KEY=xxxxx
GROQ_API_KEY=gsk_xxxxx

# Langfuse (optional for local dev)
LANGFUSE_SECRET_KEY=sk-lf-xxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx

# Supabase (production only — local uses Docker Postgres)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000